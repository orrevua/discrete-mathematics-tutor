# Copy this file to backend/.env and fill in the values. (.env is gitignored.)

# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (e.g. from Supabase or Neon).
# If left empty, the backend uses a local SQLite file (its.db) instead.
DATABASE_URL=

# Force SQLite even when DATABASE_URL is set.
# Set to "true" for quick local development.
USE_SQLITE=true

# ── Auth (Supabase) ────────────────────────────────────────────────────────
# Supabase JWKS Discovery URL (Settings → API → JWT Keys).
# The backend verifies Bearer JWTs via RS256 asymmetric keys from this URL.
# Leave empty to run without login (single "dev-user" mode).
SUPABASE_JWKS_URL=

# ── AI tutor (OpenAI-compatible endpoint) ───────────────────────────────────
# Free Gemini API key at https://aistudio.google.com (separate from any
# consumer "Google AI" subscription). Empty = tutor disabled.
TUTOR_API_KEY=
TUTOR_MODEL=gemini-2.5-flash-lite
TUTOR_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
